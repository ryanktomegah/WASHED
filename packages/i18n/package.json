{
  "name": "@washed/i18n",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./fr.json": "./src/fr.json"
  },
  "scripts": {
    "build": "node scripts/compile-fr.mjs && tsc -p tsconfig.json",
    "compile:fr": "node scripts/compile-fr.mjs",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  }
}
